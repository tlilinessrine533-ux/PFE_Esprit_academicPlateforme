@startuml
skinparam classAttributeIconSize 0

enum RoleEnum {
  ENSEIGNANT
  CHEF_DEPARTEMENT
  ADMINISTRATION
  SUPER_ADMIN
}

enum StatutActivite {
  BROUILLON
  SOUMISE
  VALIDEE_DEPARTEMENT
  VALIDEE_FINALE
  REJETEE
  A_CORRIGER
}

enum FormatRapport {
  PDF
  EXCEL
}

enum DecisionValidation {
  SOUMIS
  VALIDE
  REJETE
  A_CORRIGER
}

class Department {
  id : Long
  nom : String
}

class User {
  id : Long
  nom : String
  prenom : String
  email : String
  passwordHash : String
  role : RoleEnum
}

abstract class Activite {
  id : Long
  dateCreation : Date
  statut : StatutActivite
  anneeUniversitaire : String
}

class Enseignement {
  formation : String
  classe : String
  module : String
  semestre : String
  langue : String
  typeEnseignement : String
  heuresPrevues : double
  heuresRealisees : double
  syllabus : String
}

class Encadrement {
  typeEncadrement : String
  etudiant : String
  filiere : String
  titreSujet : String
  statutEncadrement : String
  roleJury : String
}

class Recherche {
  typePublication : String
  titre : String
  revueOuConference : String
  anneePublication : int
  indexation : String
  doi : String
}

class Evenement {
  typeEvenement : String
  titre : String
  dateEvenement : Date
  roleOrganisation : String
}

class Surveillance {
  session : String
  semestre : String
  heures : int
}

class Responsabilite {
  typeResponsabilite : String
  dateDebut : Date
  dateFin : Date
}

class ValidationHistory {
  id : Long
  dateDecision : Date
  decision : DecisionValidation
  commentaire : String
  niveauValidation : String
}

class Rapport {
  id : Long
  typeRapport : String
  format : FormatRapport
  dateGeneration : Date
  fichier : String
  periode : String
}

Department "1" -- "0..*" User
User "1" -- "0..*" Activite : cree
Activite "1" -- "0..*" ValidationHistory
User "1" -- "0..*" ValidationHistory : effectue
User "1" -- "0..*" Rapport

Activite <|-- Enseignement
Activite <|-- Encadrement
Activite <|-- Recherche
Activite <|-- Evenement
Activite <|-- Surveillance
Activite <|-- Responsabilite
@enduml
