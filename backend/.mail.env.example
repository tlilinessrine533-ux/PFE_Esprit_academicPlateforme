# Copy this file to backend/.mail.env and replace the values below with your local secrets.
# The start-dev.ps1 script loads backend/.mail.env automatically before launching Spring Boot.

# Strong JWT signing secret used by the backend.
APP_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Optional MySQL password if your local database is protected.
SPRING_DATASOURCE_PASSWORD=

# Sender shown in the password reset email.
APP_MAIL_FROM=no-reply@esprit.tn
APP_WORKFLOW_MAIL_SENDER=no-reply@esprit.tn
APP_WORKFLOW_MAIL_RH_RECIPIENT=
APP_WORKFLOW_MAIL_SCOLARITE_RECIPIENT=
APP_PASSWORD_RESET_SUBJECT=Code de verification de votre compte ESPRIT

# SMTP server settings.
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-account@example.com
SPRING_MAIL_PASSWORD=replace-with-your-password-or-app-password

# Common SMTP options.
SPRING_MAIL_AUTH=true
SPRING_MAIL_STARTTLS=true
SPRING_MAIL_STARTTLS_REQUIRED=false
SPRING_MAIL_SSL_ENABLE=false

# Useful when troubleshooting delivery issues.
SPRING_MAIL_CONNECTION_TIMEOUT=5000
SPRING_MAIL_TIMEOUT=5000
SPRING_MAIL_WRITE_TIMEOUT=5000
SPRING_MAIL_DEBUG=false

# Keep this false once SMTP is working so reset codes and transport details stay out of logs.
APP_LOG_PASSWORD_RESET_CODE=false

# Only set this if you intentionally want to bootstrap demo accounts.
APP_BOOTSTRAP_DEFAULT_PASSWORD=

# Passkey / Face ID settings. Keep these aligned with the real frontend URL.
APP_PASSKEY_RP_ID=localhost
APP_PASSKEY_ORIGIN=http://localhost:4200
APP_PASSKEY_RP_NAME=ESPRIT Academic Platform
APP_PASSKEY_CHALLENGE_TTL_MINUTES=5
APP_PASSKEY_TIMEOUT_MS=60000

# Camera face-recognition threshold. Lower = stricter match.
APP_FACE_RECOGNITION_MATCH_THRESHOLD=0.48
